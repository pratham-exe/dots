set selection-clipboard clipboard

# Dark mode by default (Gruvbox). With recolor on, the PDF's light pixels
# become recolor-lightcolor (background) and dark pixels become
# recolor-darkcolor (text).
set recolor true
set recolor-lightcolor "#282828"
set recolor-darkcolor "#ebdbb2"

# ── Light / Dark toggle ───────────────────────────────────────────────────
# NOTE: zathura 2026.07.02 has a broken `feedkeys`, so the old multi-color
# theme switches (one key setting BOTH recolor colors via feedkeys) no longer
# work. A mapped key can only run ONE `set`, so this is a reliable toggle.
map 1 set "recolor false"   # 1 → white (PDF's natural colors)
map 2 set "recolor true"    # 2 → Gruvbox dark
